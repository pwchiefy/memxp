# memxp-audit configuration
# Copy to ~/.config/memxp-audit/config.env and fill in your values
#
# Only this file contains user-specific information (IPs, paths, credentials).
# The audit scripts and prompts are generic and PII-free.

# ─── Required ──────────────────────────────────────────────

# Path to your MEMORY.md routing index
# Claude Code auto-memory lives under ~/.claude/projects/*/memory/
# Replace the project slug below with your own (check ls ~/.claude/projects/)
# MEMORY_FILE="${HOME}/.claude/projects/<your-project-slug>/memory/MEMORY.md"

# Path to your Meditation.md error journal
# The memxp installer creates this in your project directory
# MEDITATION_FILE="${HOME}/Developer/mdata/Meditation.md"

# ─── Claude Settings ──────────────────────────────────────

# Model for audit agents (sonnet recommended; haiku for cost savings)
AUDIT_MODEL="sonnet"

# Budget per verification agent (USD) — $0.75 minimum for MCP-heavy workloads
AGENT_BUDGET="0.75"

# Budget for synthesis agent (USD)
SYNTHESIS_BUDGET="1.00"

# Path to Claude CLI binary (optional — auto-discovered from PATH if not set)
# CLAUDE_PATH=""

# ─── Optional: Infrastructure Verification ─────────────────

# SSH targets for live system checks
# Format: "user@host:label" (space-separated, label used for filenames)
# Example: "root@myserver:vps admin@databox:storage"
# SSH_TARGETS=""

# ─── Optional: External Verification ──────────────────────

# GitHub org or user to check repo visibility and activity
# GH_OWNER=""

# Product URLs to health-check (space-separated)
# PRODUCT_URLS=""

# ─── Optional: Notification ──────────────────────────────

# Signal note-to-self phone number (requires signal-cli configured)
# SIGNAL_PHONE=""

# Path to signal-cli binary (optional — auto-discovered from PATH if not set)
# SIGNAL_CLI=""

# Signal CLI data directory
# SIGNAL_DATA="${HOME}/.local/share/signal-cli"

# macOS: launchd plist for Signal daemon (stopped during send, then restarted)
# SIGNAL_DAEMON_PLIST="${HOME}/Library/LaunchAgents/com.signal.daemon.plist"

# Linux: systemd user service name for Signal daemon
# SIGNAL_DAEMON_SERVICE="signal-daemon.service"

# ─── Output Locations ────────────────────────────────────

WORK_DIR="${HOME}/.local/share/memxp-audit"
OUTPUT_DIR="${HOME}/.local/share/memxp-audit/reports"

# Optional: copy report to a secondary location (e.g., iCloud, Dropbox, shared drive)
# COPY_TO=""
